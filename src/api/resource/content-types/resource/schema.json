{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Downloadable resources and documents"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": ["brochure", "certificate", "catalog", "media", "report", "other"],
      "required": true
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files", "images", "videos"]
    },
    "fileSize": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "locale": {
      "type": "string",
      "default": "en"
    }
  }
}
