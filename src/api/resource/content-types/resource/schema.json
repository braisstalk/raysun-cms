{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Downloadable resources and documents"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": ["corporate", "facility", "products", "quality", "media", "other"],
      "required": true
    },
    "resourceType": {
      "type": "enumeration",
      "enum": ["document", "video", "link"],
      "default": "document"
    },
    "status": {
      "type": "enumeration",
      "enum": ["public", "request", "restricted", "pending"],
      "default": "public"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files", "images", "videos"]
    },
    "fileSize": {
      "type": "string"
    },
    "updatedDate": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
