{
  "kind": "collectionType",
  "collectionName": "job_positions",
  "info": {
    "singularName": "job-position",
    "pluralName": "job-positions",
    "displayName": "Job Position",
    "description": "Career openings"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "department": {
      "type": "enumeration",
      "enum": ["manufacturing", "quality", "rd", "compliance", "sales", "operations", "admin"],
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "employmentType": {
      "type": "enumeration",
      "enum": ["full-time", "part-time", "contract", "internship"],
      "default": "full-time"
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "responsibilities": {
      "type": "json"
    },
    "requirements": {
      "type": "json"
    },
    "preferred": {
      "type": "json"
    },
    "postedDate": {
      "type": "date"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
