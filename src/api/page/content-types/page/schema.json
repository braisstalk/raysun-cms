{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Page-level SEO and configuration"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "seoKeywords": {
      "type": "text"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "locale": {
      "type": "string",
      "default": "en"
    },
    "content": {
      "type": "json"
    },
    "contactInquiryTypes": {
      "type": "component",
      "repeatable": true,
      "component": "page.inquiry-type"
    },
    "contactCountries": {
      "type": "component",
      "repeatable": true,
      "component": "page.country-item"
    },
    "contactOfficeEmail": {
      "type": "string"
    },
    "contactOfficePhone": {
      "type": "string"
    },
    "contactOfficeAddress": {
      "type": "text"
    },
    "contactOfficeHours": {
      "type": "string"
    },
    "verifyTypes": {
      "type": "component",
      "repeatable": true,
      "component": "page.verify-type"
    },
    "verifyHelpTitle": {
      "type": "string"
    },
    "verifyHelpDescription": {
      "type": "text"
    },
    "verifyReportTitle": {
      "type": "string"
    },
    "verifyReportDescription": {
      "type": "text"
    },
    "orderTypes": {
      "type": "component",
      "repeatable": true,
      "component": "page.order-type"
    },
    "orderPaymentMethods": {
      "type": "component",
      "repeatable": true,
      "component": "page.payment-method"
    },
    "orderTrackingPlaceholder": {
      "type": "string"
    },
    "orderHelpText": {
      "type": "text"
    },
    "orderCountries": {
      "type": "component",
      "repeatable": true,
      "component": "page.country-item"
    }
  }
}
