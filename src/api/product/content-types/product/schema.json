{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Pharmaceutical products"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "genericName": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "antibiotics",
        "cardiovascular",
        "pain",
        "dermatology",
        "vitamins",
        "gastrointestinal",
        "respiratory",
        "traditional",
        "other"
      ],
      "required": true
    },
    "dosageForm": {
      "type": "string",
      "required": true
    },
    "strength": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "indication": {
      "type": "text"
    },
    "composition": {
      "type": "text"
    },
    "packaging": {
      "type": "string"
    },
    "shelfLife": {
      "type": "string"
    },
    "storageConditions": {
      "type": "string"
    },
    "productType": {
      "type": "enumeration",
      "enum": ["brand", "generic"],
      "default": "generic"
    },
    "tags": {
      "type": "json"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "dataSheet": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "coa": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
