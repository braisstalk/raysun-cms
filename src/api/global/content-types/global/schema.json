{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Site-wide configuration"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "Raysun Biopharma"
    },
    "siteNameCn": {
      "type": "string",
      "default": "雷神生物制药"
    },
    "siteDescription": {
      "type": "text"
    },
    "contactEmail": {
      "type": "email",
      "default": "info@raysunpharma.com"
    },
    "contactPhone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "whatsappQrCode": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "wecomQrCode": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "socialLinkedin": {
      "type": "string"
    },
    "socialFacebook": {
      "type": "string"
    },
    "socialYoutube": {
      "type": "string"
    },
    "socialX": {
      "type": "string"
    },
    "socialInstagram": {
      "type": "string"
    },
    "complianceDisclaimer": {
      "type": "richtext",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "logoDark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
